{
  "name": "@sparesx/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:messaging": "jest --runTestsByPath src/messaging/__tests__/socket-auth.test.ts src/messaging/__tests__/chat.routes.test.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@sparesx/shared": "workspace:*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.41.0",
    "redis": "^4.6.10",
    "@aws-sdk/client-s3": "^3.462.0",
    "@socket.io/redis-adapter": "^8.2.0",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.2",
    "mongoose": "^7.6.1",
    "socket.io": "^4.7.2",
    "winston": "^3.10.0",
    "bull": "^4.12.2",
    "nodemailer": "^6.9.7",
    "prisma": "^5.6.0",
    "@prisma/client": "^5.6.0",
    "zod": "^3.22.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@sparesx/eslint-config": "workspace:*",
    "@sparesx/typescript-config": "workspace:*",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.8",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^10.1.4",
    "tsx": "^4.6.0",
    "typescript": "^5.2.2",
    "eslint": "^8.0.0"
  }
}





